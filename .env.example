# --- GEOGRAPHY ---
# Use a UK Postcode (e.g., LN4 4SY for RAF Coningsby) 
# OR manual coordinates below.
POSTCODE=LN4 4SY
HOME_LAT=53.093
HOME_LON=-0.171
INTERCEPT_RADIUS=15.0

# --- NETWORK & SECURITY ---
# The IP of your Google Nest / Chromecast device
NEST_IP=192.168.1.XXX
# The IP of the Windows machine running mouth.py
HOST_IP=192.168.1.YYY
MOUTH_PORT=5001
# A shared password to secure the connection between Sentry and Mouth
SHARED_SECRET=ChangeMeSuccessfully

# --- AI ---
# The local Ollama model to use for generating alerts
OLLAMA_MODEL=gemma4:e2b